######### WordPress (app01_Wordpress_mysql)
.env
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/
wp-config.php
*.sql
*.sql.gz

# WordPress writes bundled core plugins/themes into these bind-mounted
# directories on first run. Only track our own custom code here.
wp-content/plugins/*
!wp-content/plugins/cad-edu-core/
wp-content/themes/*
!wp-content/themes/cad-edu-theme/
