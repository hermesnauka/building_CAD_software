# Copy this file to .env and fill in real values.
# Never commit the real .env file (it is gitignored).

MYSQL_DATABASE=cad_edu_platform
MYSQL_USER=cad_edu_user
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_PORT=8080
PHPMYADMIN_PORT=8081

# Set to true only when behind a TLS-terminating reverse proxy in production.
FORCE_SSL_ADMIN=false
